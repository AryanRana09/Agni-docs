{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Agni",
  "colors": {
    "primary": "#FF4500",
    "light": "#FF7F50",
    "dark": "#CC3700"
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "server": "https://api.ravan.ai",
      "auth": {
        "method": "key",
        "name": "X-Api-Key"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Welcome to Agni",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "guides/authentication",
              "guides/dashboard",
              "guides/analytics",
              "guides/calls",
              "guides/appointments",
              "guides/inbound-calls",
              "guides/agents",
              "guides/tools",
              "guides/phone-numbers",
              "guides/billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Agent API",
            "pages": [
              "api-reference/agents/get",
              "api-reference/agents/list",
              "api-reference/agents/create",
              "api-reference/agents/update",
              "api-reference/agents/update-status",
              "api-reference/agents/delete"
            ]
          },
          {
            "group": "Agent Tool API",
            "pages": [
              "api-reference/tools/get",
              "api-reference/tools/list",
              "api-reference/tools/create",
              "api-reference/tools/update",
              "api-reference/tools/delete"
            ]
          },
          {
            "group": "Widget Settings API",
            "pages": [
              "api-reference/widget-settings/get",
              "api-reference/widget-settings/list",
              "api-reference/widget-settings/create",
              "api-reference/widget-settings/update",
              "api-reference/widget-settings/delete"
            ]
          },
          {
            "group": "Phone Number & Telephony API",
            "pages": [
              "api-reference/telephony/list-available-numbers",
              "api-reference/telephony/buy-number",
              "api-reference/telephony/release-number",
              "api-reference/telephony/list-purchased-numbers",
              "api-reference/telephony/import-number",
              "api-reference/telephony/create-telephony",
              "api-reference/telephony/list-twilio-numbers"
            ]
          },
          {
