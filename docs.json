          },
          {
            "group": "Cal.com Integration API",
            "pages": [
              "api-reference/calcom/oauth-connect",
              "api-reference/calcom/oauth-callback",
              "api-reference/calcom/status",
              "api-reference/calcom/list-event-types",
              "api-reference/calcom/lookup-event-type",
