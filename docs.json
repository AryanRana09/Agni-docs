    "global": {
      "anchors": [
        {
          "anchor": "Demo",
          "href": "https://agni.ravan.ai",
          "icon": "microphone"
        },
        {
          "anchor": "Website",
          "href": "https://app.ravan.ai",
          "icon": "globe"
        }
      ]
    }
