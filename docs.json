  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:hi@ravan.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Login",
      "href": "https://app.ravan.ai"
    }
  },
  "contextual": {
    "options": [
      "copy"
    ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/agnibyravan/"
